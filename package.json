{
  "name": "patron",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "check": "tsc --noEmit && jest",
    "build:android": "node -e \"const fs=require('fs'),f='app.json',j=JSON.parse(fs.readFileSync(f,'utf8')),v=j.expo.version.split('.').map(Number);v[2]++;j.expo.version=v.join('.');fs.writeFileSync(f,JSON.stringify(j,null,2)+'\\n');console.log('Version bumped to '+j.expo.version)\" && eas build --platform android --profile preview"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@supabase/supabase-js": "^2.105.4",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.76.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "private": true
}
