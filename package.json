{
  "name": "patron",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "check:consistency": "node scripts/check-consistency.js",
    "check": "tsc --noEmit && jest && node scripts/check-consistency.js",
    "test:db:start": "supabase start",
    "test:db:stop": "supabase stop",
    "test:db:reset": "node scripts/test-db-setup.js",
    "test:integration": "jest --config jest.integration.config.js",
    "build:android": "node -e \"const fs=require('fs'),f='app.json',j=JSON.parse(fs.readFileSync(f,'utf8')),v=j.expo.version.split('.').map(Number);v[2]++;j.expo.version=v.join('.');fs.writeFileSync(f,JSON.stringify(j,null,2)+'\\n');console.log('Version bumped to '+j.expo.version)\" && eas build --platform android --profile preview"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
